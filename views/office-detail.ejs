<%- include('partials/head',{title:office.name}) %><%- include('partials/nav',{title:'Kantor: '+office.name}) %>
<section class="card"><div class="toolbar"><div><h2><%= office.name %></h2><p><%= office.address||'-' %> • <%= office.city||'-' %>, <%= office.country||'-' %> • Manager: <%= office.manager||'-' %></p></div><a class="button" href="/offices">Kembali</a></div></section>
<div class="grid2"><section class="card"><h2>Group / Web di Kantor Ini</h2><table><thead><tr><th>Group</th><th>Staf Aktif</th></tr></thead><tbody><% groups.forEach(g=>{ %><tr><td><a href="/groups/<%= g.id %>/staff"><strong><%= g.name %></strong></a></td><td><%= g.staff_count %></td></tr><% }) %><% if(!groups.length){ %><tr><td colspan="2" class="empty">Belum ada group.</td></tr><% } %></tbody></table></section>
<section class="card"><h2>Semua Staf di Kantor Ini</h2><table><thead><tr><th>Staf</th><th>Group / Web</th><th>Shift / Pegang</th><th>Status</th></tr></thead><tbody><% staff.forEach(s=>{ %><tr><td><a href="/staff/<%= s.id %>"><strong><%= s.name %></strong></a><small><%= s.staff_code %></small></td><td><%= s.group_name||'-' %></td><td><%= s.shift||'-' %><small><%= s.duty||'-' %></small></td><td><span class="badge <%= s.employment_status==='ACTIVE'?'success':'warn' %>"><%= s.employment_status %></span></td></tr><% }) %><% if(!staff.length){ %><tr><td colspan="4" class="empty">Belum ada staf.</td></tr><% } %></tbody></table></section></div><%- include('partials/foot') %>
