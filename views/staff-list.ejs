<%- include('partials/head',{title:'Staf'}) %><%- include('partials/nav',{title:status==='FORMER'?'Ex Karyawan':'Data Staf'}) %>
<div class="toolbar">
  <form class="filters-wide">
    <input name="q" value="<%= q %>" placeholder="Cari nama, ID, jabatan, pekerjaan, atau email">
    <input type="hidden" name="status" value="<%= status %>">
    <select name="office"><option value="">Semua Kantor</option><% offices.forEach(o=>{ %><option value="<%= o.id %>" <%= office==o.id?'selected':'' %>><%= o.name %></option><% }) %></select>
    <select name="group"><option value="">Semua Group</option><% groups.forEach(g=>{ %><option value="<%= g.id %>" <%= group==g.id?'selected':'' %>><%= g.name %></option><% }) %></select>
    <select name="gender"><option value="">Cowok & Cewek</option><option value="MALE" <%= gender==='MALE'?'selected':'' %>>Cowok</option><option value="FEMALE" <%= gender==='FEMALE'?'selected':'' %>>Cewek</option></select>
    <select name="tenure"><option value="">Semua Lama Kerja</option><% const opts=[[3,'Minimal 3 Bulan'],[6,'Minimal 6 Bulan'],[12,'Minimal 1 Tahun'],[18,'Minimal 1,6 Tahun'],[24,'Minimal 2 Tahun'],[30,'Minimal 2,6 Tahun'],[36,'Minimal 3 Tahun'],[42,'Minimal 3,6 Tahun'],[48,'Minimal 4 Tahun'],[54,'Minimal 4,6 Tahun'],[60,'Minimal 5 Tahun'],[66,'Minimal 5,6 Tahun'],[72,'Minimal 6 Tahun'],[84,'Minimal 7 Tahun'],[90,'Minimal 7,6 Tahun'],[96,'Minimal 8 Tahun'],[108,'Minimal 9 Tahun'],[120,'Minimal 10 Tahun']];opts.forEach(t=>{ %><option value="<%= t[0] %>" <%= Number(tenure)===t[0]?'selected':'' %>><%= t[1] %></option><% }) %></select>
    <button>Filter</button><a class="button" href="/staff?status=<%= status %>">Reset</a>
  </form>
  <div class="actions"><a class="button success" href="/staff/export.xlsx?q=<%= encodeURIComponent(q) %>&status=<%= status %>&office=<%= office %>&group=<%= group %>&gender=<%= gender %>&tenure=<%= tenure %>">Download Excel Sesuai Filter</a><a class="button" href="/warnings">Daftar Staf Pernah SP</a><a class="button" href="/staff?status=<%= status==='ACTIVE'?'FORMER':'ACTIVE' %>"><%= status==='ACTIVE'?'Ex Karyawan':'Staf Aktif' %></a><a class="button primary" href="/staff/new">+ Tambah Staf</a></div>
</div>
<section class="card"><div class="section-title"><h2>Daftar Staf</h2><span class="badge"><%= items.length %> staf sesuai filter</span></div><div class="table-wrap"><table><thead><tr><th>No</th><th>Staf</th><th>Gender</th><th>Kantor / Group</th><th>Tinggal di MES / Pegang</th><th>Mulai / Lama Kerja</th><th>Email Kerja</th><th>Catatan</th><th>Aksi</th></tr></thead><tbody><% items.forEach((x,i)=>{ %><tr><td><strong><%= i+1 %></strong></td><td><div class="staff-cell"><% if(x.photo_path){ %><img class="staff-avatar" src="<%= x.photo_path %>" alt="Foto"><% }else{ %><span class="staff-avatar placeholder"><%= x.name.charAt(0) %></span><% } %><span><a href="/staff/<%= x.id %>"><strong><%= x.name %></strong></a><small><%= x.staff_code %></small></span></div></td><td><span class="badge"><%= x.gender==='FEMALE'?'Cewek':'Cowok' %></span></td><td><%= x.office_name||'-' %><small><%= x.group_name||'-' %></small></td><td><%= x.shift||'-' %><small><%= x.duty||'-' %></small></td><td><%= fmtDate(x.start_date) %><small><%= workDuration(x.start_date) %></small></td><td><%= x.work_email||'-' %></td><td><% if(x.warning_count){ %><span class="badge warn">Pernah SP: <%= x.warning_count %></span><% } %><% if(x.blacklist_level){ %><span class="badge danger">Blacklist <%= x.blacklist_level %></span><% } %></td><td><a class="button" href="/staff/<%= x.id %>">Detail</a><% if(user.role==='owner'){ %> <form class="inline" method="post" action="/staff/<%= x.id %>/delete"><button class="danger" data-confirm="Hapus permanen <%= x.name %> beserta seluruh data terkait?">Hapus</button></form><% } %></td></tr><% }) %><% if(!items.length){ %><tr><td colspan="9" class="empty">Data staf tidak ditemukan.</td></tr><% } %></tbody></table></div></section>
<%- include('partials/foot') %>
