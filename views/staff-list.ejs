<%- include('partials/head',{title:'Staf'}) %><%- include('partials/nav',{title:status==='FORMER'?'Ex Karyawan':'Data Staf'}) %>
<div class="toolbar">
  <form class="filters-wide">
    <input name="q" value="<%= q %>" placeholder="Cari nama, ID, atau pekerjaan">
    <input type="hidden" name="status" value="<%= status %>">
    <select name="group"><option value="">Semua Group</option><% groups.forEach(g=>{ %><option value="<%= g.id %>" <%= group==g.id?'selected':'' %>><%= g.name %></option><% }) %></select>
    <select name="gender"><option value="">Cowok & Cewek</option><option value="MALE" <%= gender==='MALE'?'selected':'' %>>Cowok</option><option value="FEMALE" <%= gender==='FEMALE'?'selected':'' %>>Cewek</option></select>
    <button>Filter</button>
  </form>
  <div><a class="button" href="/staff?status=<%= status==='ACTIVE'?'FORMER':'ACTIVE' %>"><%= status==='ACTIVE'?'Ex Karyawan':'Staf Aktif' %></a><a class="button primary" href="/staff/new">+ Tambah Staf</a></div>
</div>
<section class="card"><table><thead><tr><th>Staf</th><th>Gender</th><th>Kantor / Group</th><th>Shift / Pegang</th><th>Mulai</th><th>Catatan</th><th>Aksi</th></tr></thead><tbody><% items.forEach(x=>{ %><tr><td><a href="/staff/<%= x.id %>"><strong><%= x.name %></strong></a><small><%= x.staff_code %></small></td><td><span class="badge"><%= x.gender==='FEMALE'?'Cewek':'Cowok' %></span></td><td><%= x.office_name||'-' %><small><%= x.group_name||'-' %></small></td><td><%= x.shift||'-' %><small><%= x.duty||'-' %></small></td><td><%= fmtDate(x.start_date) %></td><td><% if(x.warning_count){ %><span class="badge warn">Pernah SP: <%= x.warning_count %></span><% } %><% if(x.blacklist_level){ %><span class="badge danger">Blacklist <%= x.blacklist_level %></span><% } %></td><td><a class="button" href="/staff/<%= x.id %>">Detail</a><% if(user.role==='owner'){ %> <form class="inline" method="post" action="/staff/<%= x.id %>/delete"><button class="danger" data-confirm="Hapus permanen <%= x.name %> beserta dokumen, SP, cuti, dan cashbon? Tindakan ini tidak dapat dibatalkan.">Hapus</button></form><% } %></td></tr><% }) %><% if(!items.length){ %><tr><td colspan="7" class="empty">Data staf tidak ditemukan.</td></tr><% } %></tbody></table></section>
<%- include('partials/foot') %>
