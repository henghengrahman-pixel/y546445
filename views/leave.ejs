<%- include('partials/head',{title:'Cuti'}) %><%- include('partials/nav',{title:'Pengajuan & Persetujuan Cuti'}) %>
<div class="grid2"><form class="card" method="post" action="/leave"><h2>Tambah Jadwal Cuti</h2><label>Cari Nama Staf<input id="leaveStaffSearch" placeholder="Ketik nama atau ID staf"><select id="leaveStaff" name="staff_id" required><option value="">- Pilih -</option><% staff.forEach(s=>{ %><option value="<%= s.id %>" data-label="<%= (s.name+' '+s.staff_code).toLowerCase() %>"><%= s.name %> (<%= s.staff_code %>)</option><% }) %></select></label><div id="leaveStaffSummary" class="staff-summary muted">Pilih staf untuk melihat lama kerja, terakhir cuti, SP, dan cashbon aktif.</div><div class="form-grid"><label>Mulai<input type="date" name="start_date" required></label><label>Selesai<input type="date" name="end_date" required></label></div><label>Jadwal Kontrak Kerja Selanjutnya<input type="date" name="next_contract_date" required></label><label>Jenis<input name="leave_type" value="CUTI"></label><label>Staf Pengganti<input name="replacement_staff"></label><label>Alasan<textarea name="reason"></textarea></label><button class="primary">Buat Pengajuan</button></form><section class="card"><h2>Status</h2><div class="filters"><a href="/leave?status=ALL">Semua</a><a href="/leave?status=PENDING">Pending</a><a href="/leave?status=APPROVED">ACC</a><a href="/leave?status=REJECTED">Ditolak</a></div><p>Data staf, SP, cuti, kontrak, dan cashbon terhubung melalui ID staf yang sama.</p></section></div>
<section class="card"><table><thead><tr><th>Staf</th><th>Group</th><th>Tanggal</th><th>Kontrak Berikutnya</th><th>Pengganti</th><th>Status</th><th>Aksi</th></tr></thead><tbody><% items.forEach(x=>{ %><tr><td><a href="/staff/<%= x.staff_id %>"><%= x.name %></a><small><%= x.staff_code %></small></td><td><%= x.group_name||'-' %></td><td><%= fmtDate(x.start_date) %> - <%= fmtDate(x.end_date) %></td><td><%= fmtDate(x.next_contract_date) %></td><td><%= x.replacement_staff||'-' %></td><td><span class="badge <%= x.status==='APPROVED'?'success':x.status==='REJECTED'?'danger':'warn' %>"><%= x.status %></span></td><td><form class="inline" method="post" action="/leave/<%= x.id %>/status"><button name="status" value="APPROVED" class="success">ACC</button><button name="status" value="REJECTED" class="danger">Tolak</button></form> <form class="inline" method="post" action="/leave/<%= x.id %>/delete"><button class="danger" data-confirm="Hapus pengajuan cuti ini?">Hapus</button></form></td></tr><% }) %><% if(!items.length){ %><tr><td colspan="7" class="empty">Belum ada data pengajuan cuti.</td></tr><% } %></tbody></table></section>
<%- include('partials/foot') %>