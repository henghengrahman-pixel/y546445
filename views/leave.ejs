<%- include('partials/head',{title:'Cuti'}) %><%- include('partials/nav',{title:'Pengajuan & Persetujuan Cuti'}) %><div class="grid2"><form class="card" method="post" action="/leave"><h2>Tambah Jadwal Cuti</h2><label>Staf<select name="staff_id" required><option value="">- Pilih -</option><% staff.forEach(s=>{ %><option value="<%= s.id %>"><%= s.name %> (<%= s.staff_code %>)</option><% }) %></select></label><div class="form-grid"><label>Mulai<input type="date" name="start_date" required></label><label>Selesai<input type="date" name="end_date" required></label></div><label>Jenis<input name="leave_type" value="CUTI"></label><label>Staf Pengganti<input name="replacement_staff"></label><label>Alasan<textarea name="reason"></textarea></label><button class="primary">Buat Pengajuan</button></form><section class="card"><h2>Status</h2><div class="filters"><a href="/leave?status=ALL">Semua</a><a href="/leave?status=PENDING">Pending</a><a href="/leave?status=APPROVED">ACC</a><a href="/leave?status=REJECTED">Ditolak</a></div><p>Menu <b>Cuti Mendatang</b> hanya menampilkan cuti yang sudah di-ACC.</p></section></div><section class="card"><table><thead><tr><th>Staf</th><th>Tanggal</th><th>Pengganti</th><th>Status</th><th>Aksi</th></tr></thead><tbody><% items.forEach(x=>{ %><tr><td><%= x.name %><small><%= x.office_name||'-' %> • <%= x.group_name||'-' %></small></td><td><%= fmtDate(x.start_date) %> - <%= fmtDate(x.end_date) %></td><td><%= x.replacement_staff||'-' %></td><td><span class="badge <%= x.status==='APPROVED'?'success':x.status==='REJECTED'?'danger':'warn' %>"><%= x.status %></span></td><td><form class="inline" method="post" action="/leave/<%= x.id %>/status"><button name="status" value="APPROVED" class="success">ACC</button><button name="status" value="REJECTED" class="danger">Tolak</button></form></td></tr><% }) %></tbody></table></section><%- include('partials/foot') %>
