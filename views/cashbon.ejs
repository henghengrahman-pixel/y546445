<%- include('partials/head',{title:'Cashbon PT'}) %><%- include('partials/nav',{title:'Daftar Staf Cashbon PT'}) %>
<div class="grid2"><form class="card" method="post" action="/cashbon"><h2>Tambah Cashbon PT</h2><label>Cari / Pilih Staf<input id="cashbonStaffSearch" placeholder="Ketik nama atau ID staf"><select id="cashbonStaff" name="staff_id" required><option value="">- Pilih staf -</option><% staff.forEach(s=>{ %><option value="<%= s.id %>" data-label="<%= (s.name+' '+s.staff_code).toLowerCase() %>"><%= s.name %> (<%= s.staff_code %>)</option><% }) %></select></label><div id="cashbonStaffSummary" class="staff-summary muted">Pilih staf untuk melihat lama kerja, SP, cuti terakhir, dan riwayat cashbon.</div><div class="form-grid"><label>Tanggal Pinjaman<input type="date" name="loan_date" required></label><label>Jatuh Tempo<input type="date" name="due_date"></label><label>Jumlah Pinjaman<input name="amount" inputmode="numeric" placeholder="Contoh: 2500000" required></label><label>Keperluan<input name="purpose"></label></div><label>Catatan Admin<textarea name="notes" placeholder="Keterangan uang yang dipinjam"></textarea></label><button class="primary">Tambah Cashbon</button></form>
<section class="card"><h2>Filter</h2><form class="filters-wide"><input name="q" value="<%= q %>" placeholder="Cari nama, ID staf, atau kode cashbon"><select name="status"><option value="ALL">Semua status</option><% ['PENDING','APPROVED','PAID','REJECTED'].forEach(x=>{ %><option <%= status===x?'selected':'' %>><%= x %></option><% }) %></select><button>Filter</button></form><div class="notice"><strong>Status sinkron</strong><span>PENDING = menunggu approval, APPROVED = belum dibayar, PAID = sudah dibayar.</span></div></section></div>
<section class="card"><table><thead><tr><th>Staf</th><th>Kerja / Group</th><th>Pinjaman</th><th>Status</th><th>Approval</th><th>Aksi</th></tr></thead><tbody><% items.forEach(c=>{ %><tr><td><a href="/staff/<%= c.staff_id %>"><strong><%= c.name %></strong></a><small><%= c.staff_code %> • <%= c.cashbon_code %></small></td><td><%= workDuration(c.start_date) %><small><%= c.group_name||'-' %> • <%= c.position||'-' %></small></td><td><strong>Rp <%= Number(c.amount).toLocaleString('id-ID') %></strong><small><%= fmtDate(c.loan_date) %> • jatuh tempo <%= fmtDate(c.due_date) %></small><small><%= c.notes||'' %></small></td><td><span class="badge <%= c.status==='PAID'?'success':c.status==='REJECTED'?'danger':'warn' %>"><%= c.status %></span></td><td><% if(c.status==='PAID'){ %>Lunas oleh <%= c.paid_confirmed_by_name||'-' %><small><%= c.paid_at||'' %></small><% }else{ %><%= c.approved_by_name||'Belum diproses' %><% } %></td><td><a class="button" href="/cashbon/<%= c.id %>/history">History</a><% if(c.status==='PENDING'){ %><form class="inline" method="post" action="/cashbon/<%= c.id %>/status"><button class="success" name="status" value="APPROVED">Approve</button><button class="danger" name="status" value="REJECTED">Tolak</button></form><% } %><% if(c.status==='APPROVED'){ %><form class="inline" method="post" action="/cashbon/<%= c.id %>/paid"><input type="hidden" name="payment_note" value="Sudah dibayar"><button class="success" data-confirm="Konfirmasi cashbon ini sudah dibayar?">Confirm Lunas</button></form><% } %></td></tr><% }) %><% if(!items.length){ %><tr><td colspan="6" class="empty">Belum ada data cashbon.</td></tr><% } %></tbody></table></section>
<%- include('partials/foot') %>