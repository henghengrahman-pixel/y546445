<%- include('partials/head',{title:'Kelola Multi Admin'}) %><%- include('partials/nav',{title:'Kelola Multi Admin'}) %>
<div class="grid2"><section class="card"><h2>Tambah Admin Baru</h2><p class="muted">Setiap admin akan memasang Google Authenticator 2FA miliknya sendiri saat login pertama.</p><form method="post" action="/admins"><label>Nama Admin<input name="name" required></label><label>ID Login<input name="login_id" placeholder="ADM-0002" required></label><label>Password Awal<input type="password" name="password" minlength="8" required></label><label>Hak Akses<select name="role"><option value="admin">Admin</option><option value="hr">HR</option><option value="leader">Leader</option></select></label><button class="primary full">Buat Admin</button></form></section>
<section class="card"><h2>Aturan Keamanan</h2><div class="notice"><div><strong>2FA masing-masing</strong><span>QR dan secret berbeda untuk setiap akun.</span></div></div><div class="notice warning"><div><strong>Reset oleh Super Admin</strong><span>Password dan 2FA admin lain dapat direset dari halaman ini.</span></div></div><div class="notice critical"><div><strong>Super Admin terlindungi</strong><span>Akun owner tidak dapat dinonaktifkan dari dashboard.</span></div></div></section></div>
<section class="card"><div class="section-title"><h2>Daftar Admin</h2><span><%= items.length %> akun</span></div><div class="table-wrap"><table><thead><tr><th>ID Login</th><th>Nama</th><th>Role</th><th>2FA</th><th>Status</th><th>Reset Password</th><th>Aksi</th></tr></thead><tbody><% items.forEach(a=>{ %><tr><td><strong><%= a.login_id %></strong></td><td><%= a.name %></td><td><span class="badge"><%= a.role %></span></td><td><span class="badge <%= a.totp_enabled?'success':'warn' %>"><%= a.totp_enabled?'Aktif':'Belum Dipasang' %></span></td><td><span class="badge <%= a.active?'success':'danger' %>"><%= a.active?'Aktif':'Nonaktif' %></span></td><td><% if(a.role!=='owner'){ %><form class="reset-form" method="post" action="/admins/<%= a.id %>/reset-password"><input type="password" name="password" minlength="8" placeholder="Password baru" required><button>Reset</button></form><% } else { %>-<% } %></td><td><% if(a.role!=='owner'){ %><form class="inline" method="post" action="/admins/<%= a.id %>/reset-2fa"><button>Reset 2FA</button></form> <form class="inline" method="post" action="/admins/<%= a.id %>/toggle"><button class="<%= a.active?'danger':'success' %>"><%= a.active?'Nonaktifkan':'Aktifkan' %></button></form><% } else { %><span class="badge success">Super Admin</span><% } %></td></tr><% }) %></tbody></table></div></section>
<%- include('partials/foot') %>
