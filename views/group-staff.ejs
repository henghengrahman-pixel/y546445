<%- include('partials/head',{title:'Staf '+group.name}) %><%- include('partials/nav',{title:'Staf '+group.name}) %>
<section class="card"><div class="section-title"><div><h2><%= group.name %></h2><small><%= group.office_name||'Belum terhubung ke kantor' %> • <%= items.length %> staf</small></div><a class="button primary" href="/staff/new">+ Tambah Staf</a></div>
<div class="table-wrap"><table><thead><tr><th>ID Staf</th><th>Nama</th><th>Shift</th><th>Pegang</th><th>Posisi</th><th>Mulai Kerja</th><th>Status</th><th>Catatan</th><th>Aksi</th></tr></thead><tbody><% items.forEach(x=>{ %><tr><td><%= x.staff_code %></td><td><strong><%= x.name %></strong><small><%= x.phone||'-' %></small></td><td><%= x.shift||'-' %></td><td><%= x.duty||'-' %></td><td><%= x.position||'-' %></td><td><%= fmtDate(x.start_date) %></td><td><span class="badge <%= x.employment_status==='ACTIVE'?'success':'warn' %>"><%= x.employment_status %></span></td><td><% if(x.warning_count){ %><span class="badge warn">Pernah SP: <%= x.warning_count %></span><% } %><% if(x.blacklist_level){ %><span class="badge danger">Blacklist <%= x.blacklist_level %></span><% } %></td><td><a class="button" href="/staff/<%= x.id %>">Detail</a></td></tr><% }) %><% if(!items.length){ %><tr><td colspan="9" class="empty">Belum ada staf pada group ini.</td></tr><% } %></tbody></table></div></section>
<%- include('partials/foot') %>
