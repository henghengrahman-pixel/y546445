<%- include('partials/head',{title:'Cuti Mendatang'}) %><%- include('partials/nav',{title:'Jadwal Cuti CS Mendatang (Sudah ACC)'}) %><form class="toolbar card"><select name="office"><option value="">Semua Kantor</option><% offices.forEach(o=>{ %><option value="<%= o.id %>" <%= office==o.id?'selected':'' %>><%= o.name %></option><% }) %></select><select name="group"><option value="">Semua Group</option><% groups.forEach(g=>{ %><option value="<%= g.id %>" <%= group==g.id?'selected':'' %>><%= g.name %></option><% }) %></select><button>Filter</button></form><section class="card"><table><thead><tr><th>Staf</th><th>Kantor / Group</th><th>Shift / Pegang</th><th>Jadwal Cuti</th><th>Pengganti</th><th>Disetujui</th></tr></thead><tbody><% items.forEach(x=>{ %><tr><td><a href="/staff/<%= x.staff_id %>"><strong><%= x.name %></strong></a><small><%= x.staff_code %></small></td><td><%= x.office_name||'-' %><small><%= x.group_name||'-' %></small></td><td><%= x.shift||'-' %><small><%= x.duty||'-' %></small></td><td><b><%= fmtDate(x.start_date) %></b><small>sampai <%= fmtDate(x.end_date) %></small></td><td><%= x.replacement_staff||'-' %></td><td><%= x.approved_by||'-' %></td></tr><% }) %><% if(!items.length){ %><tr><td colspan="6" class="empty">Belum ada jadwal cuti mendatang yang sudah di-ACC.</td></tr><% } %></tbody></table></section><%- include('partials/foot') %>
