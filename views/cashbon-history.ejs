<%- include('partials/head',{title:'History Cashbon'}) %><%- include('partials/nav',{title:'History Cashbon '+item.cashbon_code}) %><section class="card"><dl><dt>Staf</dt><dd><a href="/staff/<%= item.staff_id %>"><%= item.name %> (<%= item.staff_code %>)</a></dd><dt>Jumlah</dt><dd>Rp <%= Number(item.amount).toLocaleString('id-ID') %></dd><dt>Status</dt><dd><span class="badge"><%= item.status %></span></dd><dt>Catatan</dt><dd><%= item.notes||'-' %></dd></dl></section><section class="card"><h2>Riwayat Agent / Admin</h2><table><thead><tr><th>Waktu</th><th>Aksi</th><th>Perubahan</th><th>Agent</th><th>Catatan</th></tr></thead><tbody><% history.forEach(h=>{ %><tr><td><%= h.created_at %></td><td><%= h.action %></td><td><%= h.old_status||'-' %> → <%= h.new_status||'-' %></td><td><%= h.actor_name||'-' %></td><td><%= h.note||'-' %></td></tr><% }) %></tbody></table></section><%- include('partials/foot') %>