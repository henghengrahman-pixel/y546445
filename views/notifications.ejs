<%- include('partials/head',{title:'Notifikasi'}) %><%- include('partials/nav',{title:'Pusat Notifikasi'}) %><div class="toolbar"><p>Notifikasi paspor dimulai 9 bulan; visa dan WP dimulai 2 bulan sebelum habis.</p><form method="post" action="/notifications/read-all"><button>Tandai Semua Dibaca</button></form></div><section class="card"><% items.forEach(n=>{ %><div class="notice <%= n.severity.toLowerCase() %> <%= n.is_read?'read':'' %>"><div><strong><%= n.title %></strong><span><%= n.message %></span><small><%= n.created_at %></small></div><% if(!n.is_read){ %><form method="post" action="/notifications/<%= n.id %>/read"><button>Sudah Dibaca</button></form><% } %></div><% }) %></section><%- include('partials/foot') %>
