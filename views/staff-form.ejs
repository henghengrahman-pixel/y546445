<%- include('partials/head',{title:staff?'Edit Staf':'Tambah Staf'}) %><%- include('partials/nav',{title:staff?'Edit Staf':'Tambah Staf'}) %><form class="card" method="post" action="<%= staff?'/staff/'+staff.id:'/staff' %>"><div class="form-grid"><label>ID Staf<input name="staff_code" value="<%= staff?.staff_code||'' %>" <%= staff?'disabled':'' %> placeholder="Otomatis jika kosong"></label><label>Nama<input name="name" value="<%= staff?.name||'' %>" required></label><label>Telepon<input name="phone" value="<%= staff?.phone||'' %>"></label><label>Telegram<input name="telegram" value="<%= staff?.telegram||'' %>"></label><label>Kantor<select name="office_id"><option value="">- Pilih -</option><% offices.forEach(o=>{ %><option value="<%= o.id %>" <%= staff?.office_id==o.id?'selected':'' %>><%= o.name %></option><% }) %></select></label><label>Group<select name="group_id"><option value="">- Pilih -</option><% groups.forEach(g=>{ %><option value="<%= g.id %>" <%= staff?.group_id==g.id?'selected':'' %>><%= g.name %></option><% }) %></select></label><label>Shift<input name="shift" value="<%= staff?.shift||'' %>" placeholder="Pagi / Siang / Malam"></label><label>Pegang / Tugas<input name="duty" value="<%= staff?.duty||'' %>" placeholder="Deposit, WD, LiveChat"></label><label>Jabatan<input name="position" value="<%= staff?.position||'' %>"></label><label>Tanggal Mulai Kerja<input type="date" name="start_date" value="<%= staff?.start_date||'' %>"></label></div><label>Catatan<textarea name="notes"><%= staff?.notes||'' %></textarea></label><button class="primary">Simpan</button></form><%- include('partials/foot') %>
