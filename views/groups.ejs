<%- include('partials/head',{title:'Group'}) %><%- include('partials/nav',{title:'Master Group'}) %><div class="grid2"><form class="card" method="post" action="/groups"><h2>Tambah Group</h2><label>Nama Group<input name="name" required></label><label>Kantor<select name="office_id"><option value="">- Pilih -</option><% offices.forEach(o=>{ %><option value="<%= o.id %>"><%= o.name %></option><% }) %></select></label><label>Deskripsi<textarea name="description"></textarea></label><button class="primary">Tambah Group</button></form><section class="card"><h2>Daftar Group</h2><table><thead><tr><th>Group</th><th>Kantor</th><th>Status</th></tr></thead><tbody><% items.forEach(x=>{ %><tr><td><strong><%= x.name %></strong><small><%= x.description||'-' %></small></td><td><%= x.office_name||'-' %></td><td><form method="post" action="/groups/<%= x.id %>/toggle"><button class="<%= x.active?'success':'muted' %>"><%= x.active?'Aktif':'Nonaktif' %></button></form></td></tr><% }) %></tbody></table></section></div><%- include('partials/foot') %>
