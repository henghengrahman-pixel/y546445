<%- include('partials/head',{title:'Group'}) %><%- include('partials/nav',{title:'Master Group / Web'}) %>
<div class="grid2">
<form class="card" method="post" action="/groups"><h2>Tambah Group / Web</h2><p class="muted">Group tidak dikunci ke satu kantor. Satu web dapat memiliki staf di beberapa kantor.</p><label>Nama Group<input name="name" required></label><label>Deskripsi<textarea name="description"></textarea></label><button class="primary">Tambah Group</button></form>
<section class="card"><h2>Daftar Group</h2><table><thead><tr><th>No</th><th>Group</th><th>Jumlah Staf</th><th>Aksi</th></tr></thead><tbody><% items.forEach((x,i)=>{ %><tr><td><%= i+1 %></td><td><strong><%= x.name %></strong><small><%= x.description||'-' %></small></td><td><a class="button" href="/groups/<%= x.id %>/staff"><strong><%= x.staff_count||0 %></strong> staf</a></td><td><div class="actions"><button class="button" onclick="openModal('edit-group-<%= x.id %>')" type="button">Edit</button><form method="post" action="/groups/<%= x.id %>/toggle"><button class="<%= x.active?'success':'muted' %>"><%= x.active?'Aktif':'Nonaktif' %></button></form><% if(user.role==='owner'){ %><form method="post" action="/groups/<%= x.id %>/delete"><button class="danger" data-confirm="Hapus group ini?">Hapus</button></form><% } %></div></td></tr><div class="modal" id="edit-group-<%= x.id %>"><div class="modal-box"><button class="modal-close" onclick="closeModal('edit-group-<%= x.id %>')">×</button><h2>Edit Group</h2><form method="post" action="/groups/<%= x.id %>/edit"><label>Nama<input name="name" value="<%= x.name %>" required></label><label>Deskripsi<textarea name="description"><%= x.description||'' %></textarea></label><button class="primary">Simpan</button></form></div></div><% }) %><% if(!items.length){ %><tr><td colspan="4" class="empty">Belum ada group.</td></tr><% } %></tbody></table></section></div>
<%- include('partials/foot') %>
