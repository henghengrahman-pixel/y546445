<%- include('partials/head',{title:'Group'}) %><%- include('partials/nav',{title:'Master Group / Web'}) %><div class="grid2"><form class="card" method="post" action="/groups"><h2>Tambah Group / Web</h2><label>Nama Group<input name="name" required></label><label>Kantor<select name="office_id"><option value="">- Pilih -</option><% offices.forEach(o=>{ %><option value="<%= o.id %>"><%= o.name %></option><% }) %></select></label><label>Deskripsi<textarea name="description"></textarea></label><button class="primary">Tambah Group</button></form><section class="card"><h2>Daftar Group</h2><table><thead><tr><th>Group</th><th>Kantor</th><th>Staf</th><th>Aksi</th></tr></thead><tbody><% items.forEach(x=>{ %><tr><td><strong><%= x.name %></strong><small><%= x.description||'-' %></small></td><td><%= x.office_name||'-' %></td><td><a class="button" href="/groups/<%= x.id %>/staff">Lihat Staf</a></td><td><div class="actions"><button class="button" onclick="openModal('edit-group-<%= x.id %>')" type="button">Edit</button><form method="post" action="/groups/<%= x.id %>/toggle"><button class="<%= x.active?'success':'muted' %>"><%= x.active?'Aktif':'Nonaktif' %></button></form><% if(user.role==='owner'){ %><form method="post" action="/groups/<%= x.id %>/delete" onsubmit="return confirm('Hapus group ini?')"><button class="danger">Hapus</button></form><% } %></div></td></tr><div class="modal" id="edit-group-<%= x.id %>"><div class="modal-box"><button class="modal-close" onclick="closeModal('edit-group-<%= x.id %>')">×</button><h2>Edit Group</h2><form method="post" action="/groups/<%= x.id %>/edit"><label>Nama<input name="name" value="<%= x.name %>" required></label><label>Kantor<select name="office_id"><option value="">- Pilih -</option><% offices.forEach(o=>{ %><option value="<%= o.id %>" <%= String(o.id)===String(x.office_id)?'selected':'' %>><%= o.name %></option><% }) %></select></label><label>Deskripsi<textarea name="description"><%= x.description||'' %></textarea></label><button class="primary">Simpan</button></form></div></div><% }) %></tbody></table></section></div><%- include('partials/foot') %>
