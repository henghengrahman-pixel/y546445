<%- include('partials/head',{title:staff.name}) %><%- include('partials/nav',{title:staff.name}) %><div class="toolbar"><div><span class="badge"><%= staff.employment_status %></span><% if(blacklist){ %><span class="badge danger">BLACKLIST <%= blacklist.level %></span><% } %></div><a class="button" href="/staff/<%= staff.id %>/edit">Edit Staf</a></div><div class="grid2"><section class="card"><h2>Profil</h2><dl><dt>ID</dt><dd><%= staff.staff_code %></dd><dt>Kantor</dt><dd><%= staff.office_name||'-' %></dd><dt>Group</dt><dd><%= staff.group_name||'-' %></dd><dt>Shift</dt><dd><%= staff.shift||'-' %></dd><dt>Pegang</dt><dd><%= staff.duty||'-' %></dd><dt>Jabatan</dt><dd><%= staff.position||'-' %></dd><dt>Mulai Kerja</dt><dd><%= fmtDate(staff.start_date) %> • <%= workDuration(staff.start_date) %></dd><dt>Kontrak</dt><dd><%= staff.contract_term||'-' %> • berakhir <%= fmtDate(staff.contract_end_date) %></dd><dt>Catatan</dt><dd><%= staff.notes||'-' %></dd></dl></section><section class="card"><h2>Tambah Dokumen</h2><form method="post" action="/staff/<%= staff.id %>/documents" enctype="multipart/form-data"><div class="form-grid"><label>Jenis<select name="doc_type"><option value="PASSPORT">Paspor</option><option value="VISA">Visa</option><option value="WP">Work Permit</option><option value="CONTRACT">Kontrak</option></select></label><label>Nomor<input name="doc_number"></label><label>Tanggal Terbit<input type="date" name="issued_date"></label><label>Tanggal Berakhir<input type="date" name="expiry_date" required></label></div><label>File PDF/JPG/PNG<input type="file" name="file"></label><label>Catatan<textarea name="notes"></textarea></label><button class="primary">Simpan Dokumen</button></form></section></div>
<section class="card"><h2>Dokumen</h2><table><thead><tr><th>Jenis</th><th>Nomor</th><th>Berakhir</th><th>Sisa</th><th></th></tr></thead><tbody><% documents.forEach(d=>{let left=daysUntil(d.expiry_date);%><tr><td><span class="badge"><%= d.doc_type %></span></td><td><%= d.doc_number||'-' %></td><td><%= fmtDate(d.expiry_date) %></td><td class="<%= left<=30?'red':'' %>"><%= left %> hari</td><td><% if(d.file_path){ %><a href="<%= d.file_path %>" target="_blank">File</a><% } %> <form class="inline" method="post" action="/documents/<%= d.id %>/delete"><button class="danger" data-confirm="Hapus dokumen?">Hapus</button></form></td></tr><% }) %></tbody></table></section>

<section class="card"><div class="section-title"><h2>Riwayat Cashbon PT</h2><a class="button primary" href="/cashbon">+ Tambah Cashbon</a></div><table><thead><tr><th>Kode</th><th>Tanggal</th><th>Jumlah</th><th>Status</th><th>Approval / Lunas</th></tr></thead><tbody><% cashAdvances.forEach(c=>{ %><tr><td><a href="/cashbon/<%= c.id %>/history"><%= c.cashbon_code %></a></td><td><%= fmtDate(c.loan_date) %></td><td>Rp <%= Number(c.amount).toLocaleString('id-ID') %></td><td><span class="badge <%= c.status==='PAID'?'success':c.status==='REJECTED'?'danger':'warn' %>"><%= c.status %></span></td><td><%= c.paid_confirmed_by_name||c.approved_by_name||'-' %></td></tr><% }) %><% if(!cashAdvances.length){ %><tr><td colspan="5" class="empty">Belum ada cashbon.</td></tr><% } %></tbody></table></section>
<div class="grid2"><section class="card"><h2>Riwayat SP</h2><% warnings.forEach(w=>{ %><div class="notice high"><strong><%= w.level %> • <%= fmtDate(w.warning_date) %></strong><span><%= w.reason %></span></div><% }) %><form method="post" action="/staff/<%= staff.id %>/warnings"><div class="form-grid"><label>Level<select name="level"><option>TEGURAN</option><option>SP 1</option><option>SP 2</option><option>SP 3</option></select></label><label>Tanggal<input type="date" name="warning_date" required></label></div><label>Alasan<input name="reason" required></label><label>Detail<textarea name="details"></textarea></label><label>Berlaku Sampai<input type="date" name="valid_until"></label><button>Tambah SP</button></form></section><section class="card"><h2>Ex Karyawan & Blacklist</h2><% if(!former){ %><form method="post" action="/staff/<%= staff.id %>/former"><label>Tanggal Terakhir Kerja<input type="date" name="last_work_date" required></label><label>Jenis Keluar<select name="exit_type"><option>RESIGN</option><option>KONTRAK SELESAI</option><option>DIBERHENTIKAN</option><option>LAINNYA</option></select></label><label>Alasan<textarea name="exit_reason" required></textarea></label><label><input type="checkbox" name="rehire_eligible" checked> Boleh direkrut kembali</label><label>Catatan<textarea name="notes"></textarea></label><button class="danger">Pindahkan ke Ex Karyawan</button></form><% }else{ %><div class="notice warning"><strong>Ex Karyawan sejak <%= fmtDate(former.last_work_date) %></strong><span><%= former.exit_type %>: <%= former.exit_reason %></span></div><% } %><hr><% if(!blacklist){ %><form method="post" action="/staff/<%= staff.id %>/blacklist"><label>Level<select name="level"><option>LEVEL 1</option><option>LEVEL 2</option><option>LEVEL 3</option></select></label><label>Alasan<textarea name="reason" required></textarea></label><label><input type="checkbox" name="permanent" checked> Permanen</label><label>Tanggal Evaluasi<input type="date" name="review_date"></label><button class="danger">Masukkan Blacklist</button></form><% }else{ %><div class="notice critical"><strong>Blacklist <%= blacklist.level %></strong><span><%= blacklist.reason %></span></div><% if(user.role==='owner'){ %><form method="post" action="/staff/<%= staff.id %>/blacklist/remove"><button>Cabut Blacklist</button></form><% } %><% } %></section></div><%- include('partials/foot') %>
