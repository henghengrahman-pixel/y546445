<%- include('partials/head',{title:'Blacklist'}) %><%- include('partials/nav',{title:'Blacklist Staf / Ex Karyawan'}) %><section class="card"><h2>Daftar Blacklist</h2><div class="table-wrap"><table><thead><tr><th>Nama</th><th>Kantor / Group</th><th>Level</th><th>Status Staf</th><th>SP</th><th>Detail</th></tr></thead><tbody><% items.forEach(x=>{ %><tr><td><strong><%= x.name %></strong><small><%= x.staff_code %></small></td><td><%= x.office_name||'-' %><small><%= x.group_name||'-' %></small></td><td><span class="badge danger"><%= x.level %></span></td><td><%= x.employment_status %></td><td><%= x.warning_count %></td><td><button class="button" onclick="openModal('black-<%= x.id %>')">Lihat Pop-up</button></td></tr><div class="modal" id="black-<%= x.id %>"><div class="modal-box"><button class="modal-close" onclick="closeModal('black-<%= x.id %>')">×</button><h2>Blacklist: <%= x.name %></h2><div class="detail-grid"><p><b>ID:</b> <%= x.staff_code %></p><p><b>Kantor:</b> <%= x.office_name||'-' %></p><p><b>Group:</b> <%= x.group_name||'-' %></p><p><b>Shift:</b> <%= x.shift||'-' %></p><p><b>Pegangan:</b> <%= x.duty||'-' %></p><p><b>SP:</b> <%= x.warning_count %> kali</p><p><b>Level:</b> <%= x.level %></p><p><b>Permanen:</b> <%= x.permanent?'Ya':'Tidak' %></p></div><p><b>Alasan:</b><br><%= x.reason %></p><p><b>Tinjau ulang:</b> <%= fmtDate(x.review_date) %></p><a class="button" href="/staff/<%= x.staff_id %>">Buka Profil Lengkap</a></div></div><% }) %><% if(!items.length){ %><tr><td colspan="6" class="empty">Belum ada blacklist.</td></tr><% } %></tbody></table></div></section><%- include('partials/foot') %>
