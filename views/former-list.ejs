<%- include('partials/head',{title:'Ex Karyawan'}) %><%- include('partials/nav',{title:'Ex Karyawan'}) %><section class="card"><h2>Daftar Ex Karyawan</h2><div class="table-wrap"><table><thead><tr><th>Nama</th><th>Kantor / Group</th><th>Terakhir Kerja</th><th>Alasan</th><th>Rekrut Lagi</th><th>Detail</th></tr></thead><tbody><% items.forEach(x=>{ %><tr><td><strong><%= x.name %></strong><small><%= x.staff_code %></small></td><td><%= x.office_name||'-' %><small><%= x.group_name||'-' %></small></td><td><%= fmtDate(x.last_work_date) %></td><td><%= x.exit_type %></td><td><span class="badge <%= x.rehire_eligible?'success':'danger' %>"><%= x.rehire_eligible?'Boleh':'Tidak' %></span></td><td><button class="button" onclick="openModal('former-<%= x.id %>')">Lihat Pop-up</button></td></tr><div class="modal" id="former-<%= x.id %>"><div class="modal-box"><button class="modal-close" onclick="closeModal('former-<%= x.id %>')">×</button><h2><%= x.name %></h2><div class="detail-grid"><p><b>ID:</b> <%= x.staff_code %></p><p><b>Kantor:</b> <%= x.office_name||'-' %></p><p><b>Group:</b> <%= x.group_name||'-' %></p><p><b>Shift:</b> <%= x.shift||'-' %></p><p><b>Pegangan:</b> <%= x.duty||'-' %></p><p><b>Jabatan:</b> <%= x.position||'-' %></p><p><b>SP:</b> <%= x.warning_count %> kali</p><p><b>Tanggal Keluar:</b> <%= fmtDate(x.last_work_date) %></p></div><p><b>Alasan tidak bekerja lagi:</b><br><%= x.exit_reason %></p><p><b>Catatan:</b><br><%= x.notes||'-' %></p><a class="button" href="/staff/<%= x.staff_id %>">Buka Profil Lengkap</a></div></div><% }) %><% if(!items.length){ %><tr><td colspan="6" class="empty">Belum ada ex karyawan.</td></tr><% } %></tbody></table></div></section><%- include('partials/foot') %>
