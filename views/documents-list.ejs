<% const names={PASSPORT:'Masa Aktif Paspor',VISA:'Masa Aktif Visa',WP:'Masa Aktif Work Permit (WP)',CONTRACT:'Masa Aktif Kontrak'}; %>
<%- include('partials/head',{title:names[type]}) %><%- include('partials/nav',{title:names[type]}) %>
<section class="card"><div class="toolbar"><form class="filters" method="get"><input name="q" value="<%= q %>" placeholder="Cari nama, ID staf, nomor dokumen"><select name="group"><option value="">Semua Group</option><% groups.forEach(g=>{ %><option value="<%= g.id %>" <%= String(group)===String(g.id)?'selected':'' %>><%= g.name %></option><% }) %></select><button class="primary">Cari</button></form><span class="badge warn">Peringatan ≤ <%= limit %> hari</span></div>
<div class="table-wrap"><table><thead><tr><th>Staf</th><th>Kantor / Group</th><th>Nomor</th><th>Tanggal Terbit</th><th>Tanggal Berakhir</th><th>Sisa Masa Aktif</th><th>Status</th><th>Aksi</th></tr></thead><tbody>
<% items.forEach(x=>{ const d=daysUntil(x.expiry_date); const st=d<0?'Kedaluwarsa':d<=7?'Kritis':d<=30?'Segera Habis':d<=limit?'Peringatan':'Aman'; %><tr><td><strong><%= x.name %></strong><small><%= x.staff_code %> • <%= x.shift||'-' %> • <%= x.duty||'-' %></small></td><td><%= x.office_name||'-' %><small><%= x.group_name||'-' %></small></td><td><%= x.doc_number||'-' %></td><td><%= fmtDate(x.issued_date) %></td><td><%= fmtDate(x.expiry_date) %></td><td class="<%= d<=30?'red':'' %>"><%= d<0?'Lewat '+Math.abs(d)+' hari':d+' hari' %></td><td><span class="badge <%= d<0||d<=7?'danger':d<=limit?'warn':'success' %>"><%= st %></span></td><td><a class="button" href="/staff/<%= x.staff_id %>">Lihat Staf</a></td></tr><% }) %>
<% if(!items.length){ %><tr><td colspan="8" class="empty">Belum ada data <%= names[type] %>.</td></tr><% } %></tbody></table></div></section>
<%- include('partials/foot') %>
