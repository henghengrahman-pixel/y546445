<% const names={PASSPORT:'Masa Aktif Paspor',VISA:'Masa Aktif Visa',WP:'Masa Aktif Work Permit (WP)',CONTRACT:'Masa Aktif Kontrak'}; %>
<%- include('partials/head',{title:names[type]}) %><%- include('partials/nav',{title:names[type]}) %>
<section class="card"><div class="toolbar"><form class="filters" method="get"><input name="q" value="<%= q %>" placeholder="Cari nama, ID staf, nomor dokumen"><select name="group"><option value="">Semua Group</option><% groups.forEach(g=>{ %><option value="<%= g.id %>" <%= String(group)===String(g.id)?'selected':'' %>><%= g.name %></option><% }) %></select><button class="primary">Cari</button></form><div class="actions"><span class="badge warn">Peringatan ≤ <%= limit %> hari</span><button class="primary" type="button" onclick="openModal('add-document')">+ Tambah Data</button></div></div>
<div class="table-wrap"><table><thead><tr><th>Staf</th><th>Kantor / Group</th><th>Nomor</th><th>Berakhir</th><th>Sisa Aktif</th><th>Status Masa Aktif</th><th>Proses</th><th>Aksi</th></tr></thead><tbody>
<% items.forEach(x=>{ const d=daysUntil(x.expiry_date); const st=d<0?'Kedaluwarsa':d<=7?'Kritis':d<=30?'Segera Habis':d<=limit?'Peringatan':'Aman'; %><tr><td><strong><%= x.name %></strong><small><%= x.staff_code %> • <%= x.shift||'-' %> • <%= x.duty||'-' %></small></td><td><%= x.office_name||'-' %><small><%= x.group_name||'-' %></small></td><td><%= x.doc_number||'-' %></td><td><%= fmtDate(x.expiry_date) %></td><td class="<%= d<=30?'red':'' %>"><%= d<0?'Lewat '+Math.abs(d)+' hari':d+' hari' %></td><td><span class="badge <%= d<0||d<=7?'danger':d<=limit?'warn':'success' %>"><%= st %></span></td><td><span class="badge"><%= x.process_status||'ACTIVE' %></span><small><%= x.agent_name||'' %> <%= x.process_note||'' %></small></td><td><div class="actions"><button class="button" type="button" onclick="openModal('status-<%= x.id %>')">Keterangan</button><button class="success" type="button" onclick="openModal('renew-<%= x.id %>')">Sudah Diperpanjang</button><a class="button" href="/staff/<%= x.staff_id %>">Staf</a></div></td></tr>
<div class="modal" id="status-<%= x.id %>"><div class="modal-box"><button class="modal-close" onclick="closeModal('status-<%= x.id %>')">×</button><h2>Status Proses <%= names[type] %></h2><p><strong><%= x.name %></strong> • <%= x.doc_number||'-' %></p><form method="post" action="/documents/<%= x.id %>/status"><label>Status<select name="process_status"><option value="ACTIVE">Aktif / Belum Diproses</option><option value="IN_PROGRESS" <%= x.process_status==='IN_PROGRESS'?'selected':'' %>>Sedang Diperpanjang oleh Agent</option><option value="WAITING_APPROVAL" <%= x.process_status==='WAITING_APPROVAL'?'selected':'' %>>Menunggu Approval</option><option value="APPROVED" <%= x.process_status==='APPROVED'?'selected':'' %>>Sudah Approved</option><option value="PROBLEM" <%= x.process_status==='PROBLEM'?'selected':'' %>>Ada Kendala</option></select></label><label>Nama Agent<input name="agent_name" value="<%= x.agent_name||'' %>"></label><label>Keterangan<textarea name="process_note" required><%= x.process_note||'' %></textarea></label><button class="primary">Simpan Keterangan</button></form></div></div>
<div class="modal" id="renew-<%= x.id %>"><div class="modal-box"><button class="modal-close" onclick="closeModal('renew-<%= x.id %>')">×</button><h2>Masukkan Masa Aktif Terbaru</h2><form method="post" enctype="multipart/form-data" action="/documents/<%= x.id %>/renew"><label>Nomor Dokumen<input name="doc_number" value="<%= x.doc_number||'' %>"></label><div class="form-grid"><label>Tanggal Terbit Baru<input type="date" name="issued_date" value="<%= x.issued_date||'' %>"></label><label>Tanggal Berakhir Baru<input type="date" name="expiry_date" required></label></div><label>Agent<input name="agent_name" value="<%= x.agent_name||'' %>"></label><label>Keterangan<textarea name="process_note">Sudah diperpanjang dan disetujui. Masa aktif terbaru sudah dimasukkan.</textarea></label><label>Catatan Dokumen<textarea name="notes"><%= x.notes||'' %></textarea></label><label>Upload File Baru<input type="file" name="file" accept=".pdf,.jpg,.jpeg,.png,.webp"></label><button class="success">Simpan Masa Aktif Terbaru</button></form></div></div><% }) %>
<% if(!items.length){ %><tr><td colspan="8" class="empty">Belum ada data <%= names[type] %>.</td></tr><% } %></tbody></table></div></section>
<div class="modal" id="add-document"><div class="modal-box"><button class="modal-close" onclick="closeModal('add-document')">×</button><h2>Tambah <%= names[type] %></h2><form method="post" enctype="multipart/form-data" action="/documents"><input type="hidden" name="doc_type" value="<%= type %>"><label>Pilih Staf<select name="staff_id" required><option value="">- Pilih staf -</option><% staff.forEach(s=>{ %><option value="<%= s.id %>"><%= s.name %> — <%= s.staff_code %> — <%= s.group_name||'-' %> / <%= s.office_name||'-' %></option><% }) %></select></label><label>Nomor Dokumen<input name="doc_number"></label><div class="form-grid"><label>Tanggal Terbit<input type="date" name="issued_date"></label><label>Tanggal Berakhir<input type="date" name="expiry_date" required></label></div><label>Status Awal<select name="process_status"><option value="ACTIVE">Aktif</option><option value="IN_PROGRESS">Sedang Diperpanjang oleh Agent</option><option value="WAITING_APPROVAL">Menunggu Approval</option></select></label><label>Nama Agent<input name="agent_name"></label><label>Keterangan<textarea name="process_note"></textarea></label><label>Catatan<textarea name="notes"></textarea></label><label>Upload File<input type="file" name="file" accept=".pdf,.jpg,.jpeg,.png,.webp"></label><button class="primary">Simpan Data</button></form></div></div>
<%- include('partials/foot') %>
