<%- include('partials/head',{title:'Dashboard'}) %><%- include('partials/nav',{title:'Dashboard'}) %>
<div class="cards dashboard-cards">
  <div class="stat"><span>TOTAL STAF AKTIF</span><strong><%= stats.staff %></strong><small>Semua group</small></div>
  <div class="stat"><span>CUTI ACC MENDATANG</span><strong><%= stats.leave %></strong><small>Jadwal disetujui</small></div>
  <div class="stat"><span>EX KARYAWAN</span><strong><%= stats.former %></strong><small>Arsip staf</small></div>
  <div class="stat"><span>TOTAL KANTOR</span><strong><%= stats.offices %></strong><small>Kantor aktif</small></div>
  <div class="stat"><span>TOTAL GROUP</span><strong><%= stats.groups %></strong><small>Group aktif</small></div>
</div>
<div class="cards doc-cards">
  <a class="stat doc-link visa" href="/documents/visa"><span>VISA MASA AKTIF</span><strong><%= docStats.VISA %> orang</strong><small>Peringatan mulai 60 hari</small></a>
  <a class="stat doc-link passport" href="/documents/passport"><span>PASPOR MASA AKTIF</span><strong><%= docStats.PASSPORT %> orang</strong><small>Peringatan mulai 270 hari</small></a>
  <a class="stat doc-link wp" href="/documents/wp"><span>WORK PERMIT (WP)</span><strong><%= docStats.WP %> orang</strong><small>Peringatan mulai 60 hari</small></a>
  <a class="stat doc-link contract" href="/documents/contract"><span>KONTRAK MASA AKTIF</span><strong><%= docStats.CONTRACT %> orang</strong><small>Peringatan mulai 30 hari</small></a>
</div>
<div class="grid2">
<section class="card"><div class="section-title"><h2>Staf Per Group</h2><a href="/groups">Kelola group</a></div>
<div class="group-grid"><% groupStats.forEach(g=>{ %><a class="group-box" href="/groups/<%= g.id %>/staff"><strong><%= g.name %></strong><span><%= g.staff_count %> staf aktif</span><em>Lihat daftar staf →</em></a><% }) %></div>
<% if(!groupStats.length){ %><div class="empty">Belum ada group.</div><% } %></section>
<section class="card"><div class="section-title"><h2>Notifikasi Terbaru</h2><a href="/notifications">Lihat semua</a></div><% notifications.forEach(n=>{ %><div class="notice <%= n.severity.toLowerCase() %>"><div><strong><%= n.title %></strong><span><%= n.message %></span></div></div><% }) %><% if(!notifications.length){ %><div class="empty">Belum ada notifikasi.</div><% } %></section>
</div>
<div class="grid2"><section class="card"><div class="section-title"><h2>Dokumen Berdasarkan Tanggal Berakhir</h2></div><div class="table-wrap"><table><thead><tr><th>Staf</th><th>Group</th><th>Dokumen</th><th>Berakhir</th><th>Sisa</th></tr></thead><tbody><% expiring.forEach(x=>{const d=daysUntil(x.expiry_date);%><tr><td><a href="/staff/<%= x.staff_id %>"><%= x.name %></a><small><%= x.staff_code %></small></td><td><%= x.group_name||'-' %></td><td><span class="badge"><%= x.doc_type %></span></td><td><%= fmtDate(x.expiry_date) %></td><td class="<%= d<=30?'red':'' %>"><%= d < 0 ? 'Lewat '+Math.abs(d)+' hari' : d+' hari' %></td></tr><% }) %></tbody></table></div></section>
<section class="card"><div class="section-title"><h2>Jadwal Cuti Mendatang (ACC)</h2><a href="/leave/upcoming">Lihat semua</a></div><div class="table-wrap"><table><thead><tr><th>Staf</th><th>Group</th><th>Tanggal</th><th>Pengganti</th></tr></thead><tbody><% upcomingLeave.forEach(x=>{ %><tr><td><%= x.name %><small><%= x.staff_code %></small></td><td><%= x.group_name||'-' %></td><td><%= fmtDate(x.start_date) %><br>s/d <%= fmtDate(x.end_date) %></td><td><%= x.replacement_staff||'-' %></td></tr><% }) %></tbody></table></div></section></div>
<%- include('partials/foot') %>
