<%- include('partials/head',{title:'Dashboard'}) %><%- include('partials/nav',{title:'Dashboard'}) %>
<div class="cards"><% const labels=[['staff','Staf Aktif'],['offices','Kantor'],['groups','Group'],['leave','Cuti ACC Mendatang'],['former','Ex Karyawan'],['blacklist','Blacklist'],['sp','SP Aktif']]; labels.forEach(([k,l])=>{ %><div class="stat"><span><%= l %></span><strong><%= stats[k] %></strong></div><% }) %></div>
<div class="grid2"><section class="card"><div class="section-title"><h2>Dokumen Mendekati Masa Habis</h2></div><div class="table-wrap"><table><thead><tr><th>Staf</th><th>Dokumen</th><th>Berakhir</th><th>Sisa</th></tr></thead><tbody><% expiring.forEach(x=>{const d=daysUntil(x.expiry_date);%><tr><td><%= x.name %><small><%= x.office_name||'-' %> • <%= x.group_name||'-' %></small></td><td><span class="badge"><%= x.doc_type %></span></td><td><%= fmtDate(x.expiry_date) %></td><td class="<%= d<=30?'red':'' %>"><%= d %> hari</td></tr><% }) %></tbody></table></div></section>
<section class="card"><div class="section-title"><h2>Jadwal Cuti Mendatang (ACC)</h2><a href="/leave/upcoming">Lihat semua</a></div><div class="table-wrap"><table><thead><tr><th>Staf</th><th>Tanggal</th><th>Pengganti</th></tr></thead><tbody><% upcomingLeave.forEach(x=>{ %><tr><td><%= x.name %><small><%= x.group_name||'-' %></small></td><td><%= fmtDate(x.start_date) %><br>s/d <%= fmtDate(x.end_date) %></td><td><%= x.replacement_staff||'-' %></td></tr><% }) %></tbody></table></div></section></div>
<section class="card"><div class="section-title"><h2>Notifikasi Terbaru</h2><a href="/notifications">Buka pusat notifikasi</a></div><% notifications.forEach(n=>{ %><div class="notice <%= n.severity.toLowerCase() %>"><strong><%= n.title %></strong><span><%= n.message %></span></div><% }) %></section>
<%- include('partials/foot') %>
