<%- include('partials/head',{title:'Staf Pernah SP'}) %><%- include('partials/nav',{title:'Daftar Staf yang Sudah Pernah SP'}) %>
<div class="toolbar"><form class="filters-wide"><input name="q" value="<%= q %>" placeholder="Cari nama atau ID staf"><select name="office"><option value="">Semua Kantor</option><% offices.forEach(o=>{ %><option value="<%= o.id %>" <%= office==o.id?'selected':'' %>><%= o.name %></option><% }) %></select><select name="group"><option value="">Semua Group</option><% groups.forEach(g=>{ %><option value="<%= g.id %>" <%= group==g.id?'selected':'' %>><%= g.name %></option><% }) %></select><button>Filter</button><a class="button" href="/warnings">Reset</a></form></div>
<section class="card"><div class="section-title"><h2>Riwayat SP Terhubung ke Profil Staf</h2><span class="badge warn"><%= items.length %> staf</span></div><div class="table-wrap"><table><thead><tr><th>No</th><th>Staf</th><th>Kantor / Group</th><th>Jabatan</th><th>Tinggal di MES</th><th>Lama Kerja</th><th>Jumlah SP</th><th>SP Terakhir</th><th>Aksi</th></tr></thead><tbody><% items.forEach((x,i)=>{ %><tr><td><%= i+1 %></td><td><strong><%= x.name %></strong><small><%= x.staff_code %> • <%= x.work_email||'-' %></small></td><td><%= x.office_name||'-' %><small><%= x.group_name||'-' %></small></td><td><%= x.position||'-' %></td><td><%= x.shift||'-' %></td><td><%= workDuration(x.start_date) %></td><td><span class="badge warn"><%= x.warning_count %> SP</span></td><td><%= fmtDate(x.last_warning_date) %></td><td><a class="button" href="/staff/<%= x.id %>">Buka Profil & Riwayat SP</a></td></tr><% }) %><% if(!items.length){ %><tr><td colspan="9" class="empty">Belum ada staf yang memiliki SP sesuai filter.</td></tr><% } %></tbody></table></div></section>
<%- include('partials/foot') %>
