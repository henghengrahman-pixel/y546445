<%- include('partials/head',{title:'Kantor'}) %><%- include('partials/nav',{title:'Master Kantor'}) %>
<div class="grid2"><form class="card" method="post" action="/offices"><h2>Tambah Kantor</h2><label>Nama<input name="name" required></label><label>Alamat<textarea name="address"></textarea></label><div class="form-grid"><label>Negara<input name="country"></label><label>Kota<input name="city"></label></div><label>Manager<input name="manager"></label><button class="primary">Tambah Kantor</button></form>
<section class="card"><h2>Daftar Kantor</h2><table><thead><tr><th>Nama</th><th>Lokasi</th><th>Aksi</th></tr></thead><tbody><% items.forEach(x=>{ %><tr><td><a href="/offices/<%= x.id %>"><strong><%= x.name %></strong></a><small><%= x.manager||'-' %></small></td><td><%= x.city||'-' %>, <%= x.country||'-' %></td><td><div class="actions"><button class="button" type="button" onclick="openModal('edit-office-<%= x.id %>')">Edit</button><form method="post" action="/offices/<%= x.id %>/toggle"><button class="<%= x.active?'success':'muted' %>"><%= x.active?'Aktif':'Nonaktif' %></button></form><% if(user.role==='owner'){ %><form method="post" action="/offices/<%= x.id %>/delete" onsubmit="return confirm('Hapus kantor ini?')"><button class="danger">Hapus</button></form><% } %></div></td></tr>
<div class="modal" id="edit-office-<%= x.id %>"><div class="modal-box"><button class="modal-close" onclick="closeModal('edit-office-<%= x.id %>')">×</button><h2>Edit Kantor</h2><form method="post" action="/offices/<%= x.id %>/edit"><label>Nama<input name="name" value="<%= x.name %>" required></label><label>Alamat<textarea name="address"><%= x.address||'' %></textarea></label><div class="form-grid"><label>Negara<input name="country" value="<%= x.country||'' %>"></label><label>Kota<input name="city" value="<%= x.city||'' %>"></label></div><label>Manager<input name="manager" value="<%= x.manager||'' %>"></label><button class="primary">Simpan Perubahan</button></form></div></div><% }) %></tbody></table></section></div><%- include('partials/foot') %>
