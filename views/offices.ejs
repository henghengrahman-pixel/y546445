<%- include('partials/head',{title:'Kantor'}) %><%- include('partials/nav',{title:'Master Kantor'}) %><div class="grid2"><form class="card" method="post" action="/offices"><h2>Tambah Kantor</h2><label>Nama<input name="name" required></label><label>Alamat<textarea name="address"></textarea></label><div class="form-grid"><label>Negara<input name="country"></label><label>Kota<input name="city"></label></div><label>Manager<input name="manager"></label><button class="primary">Tambah Kantor</button></form><section class="card"><h2>Daftar Kantor</h2><table><thead><tr><th>Nama</th><th>Lokasi</th><th>Status</th></tr></thead><tbody><% items.forEach(x=>{ %><tr><td><strong><%= x.name %></strong><small><%= x.manager||'-' %></small></td><td><%= x.city||'-' %>, <%= x.country||'-' %></td><td><form method="post" action="/offices/<%= x.id %>/toggle"><button class="<%= x.active?'success':'muted' %>"><%= x.active?'Aktif':'Nonaktif' %></button></form></td></tr><% }) %></tbody></table></section></div><%- include('partials/foot') %>
